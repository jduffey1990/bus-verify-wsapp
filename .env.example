NODE_ENV=local

# Google Places API — get from Google Cloud Console (Maps Platform > Places API)
GOOGLE_PLACES_API_KEY=<your-google-places-api-key>

# OpenAI API — get from platform.openai.com
GPT_API_KEY=<your-openai-api-key>

# Postgres — local Docker default (brandora-verify has no DB, but these vars may be read)
PGHOST=postgres
PGPORT=5432
PGUSER=wsapp
PGPASSWORD=wsapp
PGDATABASE=wsapp
